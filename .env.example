# ===========================================================================
# Better Auth — Core
# ===========================================================================

# A long, random secret used to sign sessions and tokens.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The canonical base URL of your app (no trailing slash).
# Used by the auth client to resolve API endpoints.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================================================
# Database 
DATABASE_URL= # Replace with your database connection string
# ===========================================================================

# PostgreSQL (e.g. Neon, Supabase, PlanetScale)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================================================================
# Social Providers — Default enabled (Google, GitHub, Microsoft, Apple,
#                                     Facebook, LinkedIn)
# ===========================================================================
# Obtain credentials from each provider's developer console, then set the
# OAuth redirect/callback URL to:
#   {NEXT_PUBLIC_APP_URL}/api/auth/callback/{provider}
# e.g. http://localhost:3000/api/auth/callback/google

# --- Google ---
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub ---
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Microsoft (Azure AD) ---
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Apple ---
# https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Facebook ---
# https://developers.facebook.com/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- LinkedIn ---
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ===========================================================================
# Social Providers — Available but disabled in UI by default
# To enable: set enabled: true in components/auth/providers.ts
# ===========================================================================

# --- Discord ---
# https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Twitter / X ---
# https://developer.x.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# --- Twitch ---
# https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Spotify ---
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===========================================================================
# Demo / Showcase Mode
# ===========================================================================
# Set NEXT_PUBLIC_DEMO_MODE=true to run the app as a public showcase:
#   - Sign-in uses DEMO_EMAIL + DEMO_PASSWORD (no database required)
#   - Sign-up page shows a notice telling visitors to clone the repo
#   - Social providers are hidden
#
# To disable demo mode (after you clone and set up your own DB): remove
# NEXT_PUBLIC_DEMO_MODE or set it to "false". Normal Better Auth takes over.


NEXT_PUBLIC_DEMO_MODE=false

# Credentials visitors should use to explore the dashboard (set on Vercel)
DEMO_EMAIL=
DEMO_PASSWORD=
